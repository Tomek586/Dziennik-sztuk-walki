# Skopiuj do apps/app/.env i uzupełnij wartościami z Twojego projektu Supabase.
# (Settings → API w panelu Supabase)

# Publiczne (bezpieczne w bundlu klienta) — muszą mieć prefiks EXPO_PUBLIC_
EXPO_PUBLIC_SUPABASE_URL=https://twoj-projekt.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=twoj-anon-key

# Sekrety SERWEROWE — NIGDY w aplikacji klienckiej.
# Ustawiane wyłącznie w Supabase (Edge Functions secrets), nie w tym pliku w repo.
# CLAUDE_API_KEY=...
# YOUTUBE_API_KEY=...
# STT_API_KEY=...
# SUPABASE_SERVICE_ROLE_KEY=...
